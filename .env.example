# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template environment variables for AI-RAGSystem
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the actual `.env` file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Override default Gemini model
LLM_MODEL=gemini-flash-lite-latest

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
# Get from: https://cloud.qdrant.io
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here

# ── CloudAMQP (RabbitMQ) ──────────────────────────────────────────────────────
# Get from: https://www.cloudamqp.com/
# Format: amqps://user:password@host/vhost
# For local dev with docker-compose, use: amqp://guest:guest@rabbitmq:5672/
CLOUDAMQP_URL=amqps://your-user:your-password@your-host.cloudamqp.com/your-vhost

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Production: your Azure Container Apps URL
# Development: http://localhost:80,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:80,http://localhost:3000

# ── App settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
COLLECTION_NAME=my_collection
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
USER_AGENT=SiTukang-RAG/1.0

# ── Local Qdrant fallback (used only when QDRANT_URL is empty) ────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Worker settings ───────────────────────────────────────────────────────────
AMQP_QUEUE_INJECT=rag.inject
AMQP_EXCHANGE=rag
WORKER_PREFETCH_COUNT=1
WORKER_MAX_RETRIES=3
